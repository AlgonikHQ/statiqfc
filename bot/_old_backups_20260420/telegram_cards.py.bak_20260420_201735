# ── PRIVATE: Morning pre-scan briefing ───────────────────────

def card_private_morning_briefing(fixtures, version):
    total = len(fixtures)
    by_league = defaultdict(list)
    for f in fixtures:
        by_league[f.get("league", "PL")].append(f)

    lines = [
        f"🌅 *Morning Briefing — {datetime.utcnow().strftime(\"%d %b %Y\")}*\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"📋 {total} fixture(s) to scan today\n"
    ]
    for league_code, lf in sorted(by_league.items()):
        lines.append(f"\n{_league_label(league_code)}")
        for f in lf:
            ko = _ko_time(f["kickoff_utc"])
            lines.append(f"  ⚽ {f[\'home\']} vs {f[\'away\']} — {ko}")

    lines.append(f"\n\n_Edge scans fire 2hrs before each KO._")
    lines.append(f"\n⚙️ StatiqFC {version}")
    return "\n".join(lines)

