        f"Staked:     £{roi[\'total_staked\']}\n"
        f"Returned:   £{roi[\'total_return\']}\n"
        f"Net P&L:    {sign(roi[\'net_pl\'])}£{roi[\'net_pl\']}\n"
        f"ROI:        {sign(roi[\'roi_pct\'])}{roi[\'roi_pct\']}%\n\n"
