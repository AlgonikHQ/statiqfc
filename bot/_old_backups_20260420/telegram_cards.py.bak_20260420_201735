# ── PUBLIC: Daily digest ──────────────────────────────────────

def card_daily_digest(fixtures):
    by_league = defaultdict(list)
    for f in fixtures:
        by_league[f.get("league", "PL")].append(f)

    lines = ["📋 *Today\'s Fixtures*\n"]
    for league_code, lf in sorted(by_league.items()):
        lines.append(f"\n{_league_label(league_code)}")
        for f in lf:
            ko = _ko_time(f["kickoff_utc"])
            lines.append(f"  ⚽ {f[\'home\']} vs {f[\'away\']} — {ko}")
    lines.append("\nEdge Alerts fire 2hrs before kick-off.")
    return "\n".join(lines)

# ── PUBLIC: Edge alert ────────────────────────────────────────

def card_edge_alert(edge, form_home, form_away, h2h_rows, odds, version):
    home         = edge["home"]
    away         = edge["away"]
    market       = edge["market"]
    stake        = edge["stake"]
    odds_val     = edge["odds"]
    potential    = edge["potential"]
    ko           = _ko_time(edge["kickoff"])
    reasoning    = edge.get("reasoning", "")
    league_code  = edge.get("league", "PL")
    league_label = _league_label(league_code)
    score_str    = edge.get("score_str", "?/6")
    layers       = edge.get("layers", [])

    market_labels = {
        "BTTS":    "Both Teams to Score",
        "CS_HOME": "Home Clean Sheet",
        "OVER25":  "Over 2.5 Goals"
    }
    market_label = market_labels.get(market, market)
    sel_type     = "🔨 *Builder Single*" if edge.get("is_builder") else "⚡ *Edge Alert*"

    h_form = _form_emoji(form_home.get("last5_list", [])) if form_home else "N/A"
    a_form = _form_emoji(form_away.get("last5_list", [])) if form_away else "N/A"

    h2h_summary = ""
    if h2h_rows:
        h2h_lines   = [f"  {r[\'home\']} {r[\'home_score\']}–{r[\'away_score\']} {r[\'away\']} ({r[\'date\']})" for r in h2h_rows[:3]]
        h2h_summary = "\n\n*H2H (last 3)*\n" + "\n".join(h2h_lines)

    odds_line = ""
    if odds:
        odds_line = (
            f"\n\n*Reference odds (snapshot)*"
            f"\n  {home} win: {odds.get(\'home\',\'N/A\')}"
            f"\n  Draw: {odds.get(\'draw\',\'N/A\')}"
            f"\n  {away} win: {odds.get(\'away\',\'N/A\')}"
            f"\n  ⏱️ Verify before placing"
        )

    # Show top 3 layers publicly
    layers_short = " | ".join(layers[:3]) if layers else ""

    return (
        f"{sel_type}\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"🏆  {league_label}\n"
        f"🏟️  *{home} vs {away}*\n"
        f"⏰  Kick-off: {ko}\n\n"
        f"📌  *Market:* {market_label}\n"
        f"💷  Stake: £{stake}  |  Odds: {odds_val}  |  Potential: £{potential}\n\n"
        f"📊  *Form (last 5)*\n"
        f"  {home}: {h_form}\n"
        f"  {away}: {a_form}\n\n"
        f"🔢  *Stat basis*\n"
        f"  {reasoning}\n\n"
        f"📐  *Signal strength: {score_str}*\n"
        f"  {layers_short}"
        f"{h2h_summary}"
        f"{odds_line}"
        f"{DISCLAIMER}"
        f"{FOOTER.format(version=version)}"
    )

# ── PUBLIC: Per-fixture skip card ────────────────────────────

def card_fixture_skip(home, away, league, kickoff_utc, score, max_score, next_ko=None):
    ko           = _ko_time(kickoff_utc)
    league_label = _league_label(league)
    next_line    = f"\nNext fixture in window: {next_ko}" if next_ko else ""
    return (
        f"🔍 *No edge — {home} vs {away}*\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"{league_label} | {ko}\n\n"
        f"Scanned this fixture — signal scored {score}/{max_score}.\n"
        f"Conditions didn\'t meet our threshold.{next_line}\n\n"
        f"_Scanning remaining fixtures as scheduled._"
    )

