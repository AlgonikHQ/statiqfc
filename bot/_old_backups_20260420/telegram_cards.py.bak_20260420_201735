from datetime import datetime
from collections import defaultdict

LEAGUE_LABELS = {
    "PL":  "🏴󠁧󠁢󠁥󠁮󠁧󠁿 Premier League",
    "BL1": "🇩🇪 Bundesliga",
    "SA":  "🇮🇹 Serie A",
    "FL1": "🇫🇷 Ligue 1",
    "PD":  "🇪🇸 La Liga",
    "CL":  "⭐ Champions League",
    "EC":  "🌍 European Championship",
    "WC":  "🌎 World Cup",
}

DISCLAIMER = "\n\n⚠️ Paper portfolio only. No financial advice. 18+ Gamble responsibly."
FOOTER     = "\n\n⚙️ StatiqFC {version} | data: football-data.org + Understat + API-Football"

def _ko_time(utc_str):
    try:
        dt = datetime.fromisoformat(utc_str.replace("Z", "+00:00"))
        return dt.strftime("%H:%M UTC")
    except Exception:
        return utc_str

def _form_emoji(wdl_list):
    mapping = {"W": "🟢", "D": "🟡", "L": "🔴"}
    return " ".join(mapping.get(r, "⬜") for r in wdl_list)

def _league_label(code):
    return LEAGUE_LABELS.get(code, code)

