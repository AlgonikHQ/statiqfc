# ── PRIVATE: Near-miss log ────────────────────────────────────

def card_private_near_misses(near_misses, version):
    if not near_misses:
        return None
    lines = [
        "📋 *Near-Miss Picks Today*\n"
        "━━━━━━━━━━━━━━━━━\n"
        "These fixtures scored 3/6 — just below threshold:\n"
    ]
    for nm in near_misses:
        league = _league_label(nm.get("league", "PL"))
        layers = " | ".join(nm.get("layers", []))
        lines.append(
            f"\n🏟️ {nm[\'home\']} vs {nm[\'away\']} [{nm[\'market\']}]\n"
            f"  {league} | Score: {nm[\'score\']}/6\n"
            f"  {layers}"
        )
    lines.append(f"\n\n_Threshold is 4/6. Adjust in config if needed._")
    lines.append(f"\n⚙️ StatiqFC {version}")
    return "\n".join(lines)

# ── PRIVATE: Nightly cache report ────────────────────────────

def card_private_nightly_report(ok, data_sources, api_budget=None):
    status = "✅ All sources OK" if ok else "⚠️ Some sources failed"
    lines  = [
        f"🔄 *Nightly Cache Report*\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"Status: {status}\n"
        f"Time: {datetime.utcnow().strftime(\"%H:%M UTC\")}\n\n"
        f"*Data sources:*\n"
    ]
    for source, source_ok in data_sources.items():
        icon = "✅" if source_ok else "❌"
        lines.append(f"  {icon} {source}")

    if api_budget is not None:
        lines.append(f"\n\n*API-Football budget:*\n  Used today: {api_budget} / 100 requests")

    return "\n".join(lines)

